# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# Entorno: development | testing | production
FLASK_ENV=development

# Clave secreta de sesión (cámbiala en producción, usa algo aleatorio largo)
SECRET_KEY=cambiar-esta-clave-en-produccion

# ── Base de datos ──────────────────────────────────────────────────────────────
# Desarrollo (Docker local):
DATABASE_URL=postgresql://encuesta_user:encuesta_pass@localhost:5432/encuesta_dev

# Producción (ejemplo):
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/encuesta_prod
